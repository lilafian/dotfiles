{
    "position": "bottom",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["clock"],
    "clock": {
        "format": "{:%a %b %d %y | %I:%M %p}"
    },
    "margin-bottom": 10,
    "margin-left": 20,
    "margin-right": 20,
    "reload_style_on_change": true
}
